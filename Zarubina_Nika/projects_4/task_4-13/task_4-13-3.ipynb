   ],
   "source": [
    "n = int(input(\"Введите N: \"))\n",
    "f = 1\n",
    "i = 1\n",
    "while i <= n:\n",
    "    f = f * i  \n",
    "    i = i + 1\n",
    "print(\"Факториал\", n, \"равен\", f)"
   ]
  }
