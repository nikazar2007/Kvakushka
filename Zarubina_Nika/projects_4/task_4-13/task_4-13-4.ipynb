   ],
   "source": [
    "n = int(input(\"Введите N: \"))\n",
    "s = 0\n",
    "i = 1\n",
    "while i <= n:\n",
    "    s = s + i   \n",
    "    i = i + 1   \n",
    "print(\"Сумма первых\", n, \"натуральных чисел:\", s)"
   ]
  }
 ],
