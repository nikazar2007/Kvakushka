     "text": [
      "Введите N:  4\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Сумма квадратов первых 4 натуральных чисел: 31\n"
     ]
    }
   ],
   "source": [
    "n = int(input(\"Введите N: \"))\n",
    "sum_ = 1\n",
    "i = 1\n",
    "while i <= n:\n",
    "    sq = i ** 2\n",
    "    sum_ = sum_ + sq\n",
    "    i = i + 1\n",
    "print(\"Сумма квадратов первых\", n, \"натуральных чисел:\", sum_)"
   ]
  }
 ],
