   "source": [
    "array = [64, 34, 25, 12, 22, 11, 90]\n",
    "n = len(array)\n",
    "i = 0\n",
    "count = 0\n",
    "\n",
    
    "while i < n:\n",
    "    if array[i] > 0:\n",
    "        count = count + 1\n",
    "    i = i + 1\n",
    "\n",
    
    "print(\"Количество положительных чисел в массиве:\", count)"
   ]
  }
